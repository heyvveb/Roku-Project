<?xml version="1.0" encoding="UTF-8"?>
<component name="MainScene" extends="Scene">
    <script type="text/brightscript" uri="MainScene.brs" />
    <script type="text/brightscript" uri="UILogic/ScreenStackLogic.brs" />
    <script type="text/brightscript" uri="UILogic/ContentTaskLogic.brs" />
    <script type="text/brightscript" uri="UILogic/GridScreenLogic.brs" />
    <script type="text/brightscript" uri="UILogic/VideoPlayerLogic.brs" />
    <script type="text/brightscript" uri="UILogic/DetailsScreenLogic.brs" />
    <script type="text/brightscript" uri="UILogic/EpisodesScreenLogic.brs" />
    <children>
        <!-- Overhang logo in screen -->
        <Overhang
            id="overhang"
            showOptions="false"
            showClock="false"
            logoUri="pkg:/images/hd_overhang_log.png"
            translation="[-30,-10]"
            color="0x171a14"
            height="150"
        />
        <Label
        id="overhangTitle"
        text="FIFA WORLD CUP 2026"
        vertAlign="center"
        translation="[180, -10]"
        height="200"
        width="600"
        font= "font:LargeBoldSystemFont"
        >
        </Label>
        <!-- Loading indicator when waiting for content -->
        <label
            id="loadingIndicator"
            text="Loading..."
            width="1280"
            height="720"
            translation="[0,0]"
            horizAlign="center"
            vertAlign="center"
            visible="false"
            font="font:LargeBoldSystemFont"
        />
    </children>
</component>