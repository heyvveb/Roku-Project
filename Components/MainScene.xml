<?xml version="1.0" encoding="UTF-8"?>
<component name="MainScene" extends="Scene">
    <script type="text/brightscript" uri="MainScene.brs" />
    <script type="text/brightscript" uri="UILogic/ScreenStackLogic.brs" />
    <script type="text/brightscript" uri="UILogic/ContetTaskLogic.brs" />
    <script type="text/brightscript" uri="UILogic/GridScrennLogic.brs" />
    <children>
        <!-- Overhang logo in screen -->
        <Overhang
            id="overhang"
            showOptions="false"
            showClock="false"
            logoUri="pkg:/images/hd_overhang_log.png"
            translation="[0.60]"
        />
        <!-- Loading indicator when waiting for content -->
        <label
            id="loadingIndicator"
            text="Loading..."
            width="1280"
            hight="720"
            translation="[0,0]"
            horizAlign="center"
            vertAlign="center"
            visible="false"
            font="font:LargeBoldSystemFont"
        />
    </children>
</component>